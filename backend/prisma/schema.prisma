// ============================================
// CoopElos 4.0 - Database Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  rh
  dp
  viewer
}

enum Gender {
  masculine
  feminine
}

enum MaritalStatus {
  single
  married
  divorced
  widowed
  other
}

enum CollaboratorStatus {
  active
  inactive
  suspended
}

enum TaskStatus {
  pending
  in_progress
  completed
  overdue
}

enum PayrollStatus {
  draft
  processing
  closed
  cancelled
}

// ============================================
// CORE TABLES
// ============================================

/// Multi-tenant cooperative
model Cooperative {
  id            String   @id @default(uuid())
  name          String
  cnpj          String?  @unique
  logo_url      String?
  address       String?
  phone         String?
  email         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  users          User[]
  tasks          Task[]
  audit_logs     AuditLog[]
  ficha_cooperados FichaCooperadoForm[]

  @@map("cooperative")
}

/// System users (admin, rh, dp, viewer)
model User {
  id            String   @id @default(uuid())
  cooperative_id String
  cooperative   Cooperative @relation(fields: [cooperative_id], references: [id])
  
  name          String
  username      String?  @unique
  email         String
  password_hash String
  role          UserRole @default(viewer)
  is_active     Boolean  @default(true)
  last_login    DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  created_tasks   Task[]       @relation("TaskCreator")
  assigned_tasks  Task[]       @relation("TaskAssignee")
  audit_logs      AuditLog[]

  @@unique([cooperative_id, email])
  @@map("user")
}

/// Employee/worker record
model Collaborator {
  id            String   @id @default(uuid())
  
  // Core fields
  full_name     String
  cpf           String   @unique
  cel           String?
  email         String?

  @@map("collaborator")
}

// ============================================
// TASKS (Tarefas)
// ============================================

model Task {
  id            String   @id @default(uuid())
  cooperative_id String
  cooperative   Cooperative @relation(fields: [cooperative_id], references: [id])
  
  title         String
  description   String?
  status        TaskStatus @default(pending)
  priority      Int      @default(0)
  
  due_date      DateTime?
  completed_at  DateTime?
  
  creator_id    String
  creator       User     @relation("TaskCreator", fields: [creator_id], references: [id])
  
  assignee_id   String?
  assignee      User?    @relation("TaskAssignee", fields: [assignee_id], references: [id])
  
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([cooperative_id, status, due_date])
  @@map("task")
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id            String   @id @default(uuid())
  cooperative_id String
  cooperative   Cooperative @relation(fields: [cooperative_id], references: [id])
  
  user_id       String?
  user          User?    @relation(fields: [user_id], references: [id])
  
  action        String   // CREATE, UPDATE, DELETE
  table_name    String
  record_id     String
  
  old_data      Json?    @db.JsonB
  new_data      Json?    @db.JsonB
  
  ip_address    String?
  user_agent    String?
  
  created_at    DateTime @default(now())

  @@index([cooperative_id, created_at])
  @@map("audit_log")
}

// ============================================
// FICHA COOPERADO FORM (importação Bubble)
// ============================================

model FichaCooperadoForm {
  id                    String   @id @default(uuid())
  cooperative_id        String
  cooperative           Cooperative @relation(fields: [cooperative_id], references: [id])

  // Controle
  cooperado_number      Int?
  status                String   @default("active")

  // Dados de identificação
  venc_cooperados       String?  // 1º Venc_Cooperados
  matricula             String?
  unique_id_bubble      String?  @unique  // unique id (Bubble)
  slug                  String?

  // Dados pessoais
  nome_cooperado        String?
  cpf_cooperado         String?
  rg                    String?
  nis_pis               String?
  ctps_serie            String?
  nacionalidade         String?
  naturalidade          String?
  nascimento            DateTime?
  sexo                  String?
  estado_civil          String?
  escolaridade          String?
  nome_pai              String?
  nome_mae              String?
  nome_conjuge          String?
  cpf_conjuge           String?

  // Contato
  celular_cooperado     String?
  telefone_residencial  String?
  email_cooperado       String?
  celular_indicador     String?
  email_indicador       String?
  nome_indicacao        String?
  email_gestor          String?

  // Endereço
  endereco              String?
  bairro                String?
  complemento           String?
  cep                   String?
  cidade                String?
  estado                String?

  // Dados profissionais
  empresa_trabalho      String?
  cargo_pretendido      String?
  cargo_contratado      String?
  salario               String?
  data_admissao         DateTime?
  data_cadastro         DateTime?

  // Atividades
  ativ_coop_dropa       String?
  ativ_coop_dropb       String?
  atividades_cooperados String?
  outras_ativd_profissionais String?

  // Dados bancários
  banco                 String?
  agencia               String?
  conta_corrente        String?
  pix                   String?
  capital_social        String?

  // Documentos e checklist
  carteira_registro     String?
  atestados_tecnicos    String?
  curriculo_profissional String?
  descricao_sucinta     String?

  // Valores
  valor_acumulado       String?
  valor_atual           String?
  valor_integralizado   String?
  valor_var             String?

  // Outros
  parcelas              String?
  em_aberto             String?
  local_cadastro        String?
  imagem_cooperado      String?

  // Metadados Bubble
  creation_date         DateTime?
  modified_date         DateTime?
  creator               String?

  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@index([cooperative_id, cpf_cooperado])
  @@map("ficha_cooperado_form")
}
